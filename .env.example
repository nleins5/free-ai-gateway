# Routing behavior
APP_NAME=free-ai-gateway
ROUTING_MODE=weighted
PROVIDER_CHAIN=cloudflare,github,groq,openrouter,gemini,huggingface,cerebras,sambanova,freetheai,ollama
REQUEST_TIMEOUT_S=30
MAX_RETRIES_PER_PROVIDER=1
PROVIDER_FAILURE_THRESHOLD=2
PROVIDER_COOLDOWN_S=60
ADAPTIVE_ROUTING=1
ADAPTIVE_LATENCY_ALPHA=0.3
ADAPTIVE_ERROR_PENALTY=0.5

# RAG settings (local store)
RAG_STORE_PATH=.rag_store.json
RAG_TOP_K=4
RAG_MAX_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP_CHARS=120

# Used when ROUTING_MODE=weighted. Higher = more traffic share.
PROVIDER_WEIGHTS_JSON='{"cloudflare":4,"github":2,"groq":3,"openrouter":2,"gemini":2,"huggingface":1,"cerebras":1,"sambanova":1,"freetheai":1,"ollama":1}'

# Optional: virtual model aliases mapped per provider.
# Send model: "smart-chat" (or cf-dynamic/fast-free/reasoning-free/gemma-free/gemma-fast/gemma-quality/gemma-max) to the chat endpoint.
MODEL_ALIAS_JSON='{"smart-chat":{"cloudflare":"dynamic/default","github":"openai/gpt-4o-mini","groq":"llama-3.1-8b-instant","openrouter":"openrouter/free","gemini":"gemini-2.5-flash","huggingface":"Qwen/Qwen2.5-72B-Instruct","cerebras":"llama-3.3-70b","sambanova":"Llama-3.1-8B-Instruct","freetheai":"wsf/kimi-k2.6","ollama":"llama3.1:8b"},"cf-dynamic":{"cloudflare":"dynamic/default"},"fast-free":{"cloudflare":"dynamic/default","groq":"llama-3.1-8b-instant","openrouter":"meta-llama/llama-3.1-8b-instruct:free","gemini":"gemini-2.5-flash","huggingface":"Qwen/Qwen2.5-72B-Instruct","cerebras":"llama-3.3-70b","ollama":"llama3.1:8b"},"reasoning-free":{"github":"deepseek/deepseek-r1","openrouter":"deepseek/deepseek-r1:free","groq":"deepseek-r1-distill-llama-70b"},"gemma-free":{"groq":"gemma2-9b-it","openrouter":"google/gemma-2-9b-it:free","ollama":"gemma2:9b"},"gemma-fast":{"groq":"gemma2-9b-it","openrouter":"google/gemma-2-9b-it:free","ollama":"gemma2:9b"},"gemma-quality":{"groq":"gemma2-27b-it","openrouter":"google/gemma-2-27b-it:free","ollama":"gemma2:27b"},"gemma-max":{"openrouter":"google/gemma-2-27b-it:free","groq":"gemma2-27b-it","ollama":"gemma2:27b"}}'

# GitHub Models. The app accepts either GITHUB_TOKEN or GITHUB_PAT.
GITHUB_TOKEN=
GITHUB_PAT=
GITHUB_MODEL=openai/gpt-4o-mini

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Cloudflare AI Gateway (OpenAI-compatible URL)
# Example: https://gateway.ai.cloudflare.com/v1/<account>/<gateway>/compat
CLOUDFLARE_API_KEY=
CLOUDFLARE_BASE_URL=
CLOUDFLARE_MODEL=dynamic/default
# Cloudflare Workers AI image generation (direct API)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini OpenAI-compatible endpoint
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Hugging Face Inference
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-72B-Instruct
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Cerebras
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# SambaNova
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Llama-3.1-8B-Instruct

# FreeTheAI
FREETHEAI_API_KEY=
FREETHEAI_MODEL=wsf/kimi-k2.6

# xAI (Grok)
XAI_API_KEY=
XAI_MODEL=grok-4.1-fast

# Together AI
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Claude (Anthropic) — works with official API or free proxies
# Set CLAUDE_BASE_URL to point to a proxy (e.g. claude-max-api-proxy)
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com/v1
CLAUDE_MODEL=claude-sonnet-4-20250514

# NVIDIA NIM (free tier — 5000 req/day)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Ollama local fallback
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1:8b

# 9Router local routing
NINEROUTER_API_KEY=
NINEROUTER_BASE_URL=http://localhost:20128/v1
NINEROUTER_MODEL=claude-3-5-sonnet-20241022

# Doubleword AI
DOUBLEWORD_API_KEY=
DOUBLEWORD_MODEL=moonshotai/Kimi-K2.6

