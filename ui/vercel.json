{
  "redirects": [
    {
      "source": "/docs",
      "destination": "https://free-ai-gateway.onrender.com/docs",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/v1/(.*)", "destination": "https://free-ai-gateway.onrender.com/v1/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
